*.pdf
*.zip
*.png

# Local .terraform directories
**/.terraform/*

# .tfstate files - NEVER commit these
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude .tfvars files (likely contain sensitive data)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: Ignore plan files
*.tfplan
*.tfplan.*   